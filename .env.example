# Copy this file to .env and fill in your own values.
# NEVER commit .env — it is in .gitignore.

# HuggingFace credentials (required for pyannote & gated models)
HUGGINGFACE_TOKEN=hf_YOUR_TOKEN_HERE
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Whisper model (e.g. base.en, small.en, medium.en, large-v3)
WHISPER_MODEL_NAME=base.en

# Pyannote diarization model
PYANNOTE_MODEL_NAME=pyannote/speaker-diarization-3.1

# Set to true to run the local LLM refinement stage
RUN_LOCAL_LLM=true

# Qwen2.5 model for refinement (3B or 7B variant)
LOCAL_LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Optional: override default HuggingFace cache location
# HF_HOME=/path/to/hf_cache
# HF_HUB_CACHE=/path/to/hf_cache/hub
# TRANSFORMERS_CACHE=/path/to/hf_cache/transformers
